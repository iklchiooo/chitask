// ══════════════════════════════════════════════
// ⚔️ BOSS BATTLE RPG — Full Redesign v3
// ══════════════════════════════════════════════

// ── Boss Registry ──
// BOSS_DEFS diisi secara dinamis oleh tiap file boss_*.js
// Urutan boss ditentukan oleh urutan load script di HTML
var BOSS_DEFS = [];
var _bossSprites = {};  // { id: spriteFunction }

// CT_Boss.register(def) — dipanggil oleh tiap boss_*.js
// def wajib punya: id, name, sub, maxHp, col, glow, aura, death,
//                  phrase[], ragePhrases[], sprite(ctx,pct,defeated,P)
window.CT_Boss = {
  register: function(def) {
    if (!def || !def.id) { console.warn('[CT_Boss] register: def.id wajib ada'); return; }
    // Simpan sprite function terpisah, jangan masuk ke BOSS_DEFS
    _bossSprites[def.id] = def.sprite || function(){};
    var d = {};
    for (var k in def) { if (k !== 'sprite') d[k] = def[k]; }
    // Cegah duplikat
    for (var i = 0; i < BOSS_DEFS.length; i++) {
      if (BOSS_DEFS[i].id === def.id) { BOSS_DEFS[i] = d; return; }
    }
    BOSS_DEFS.push(d);
    console.log('[CT_Boss] Registered:', def.id, '(' + BOSS_DEFS.length + ' bosses total)');
  }
};

var bossState = { idx:0, hp:0, maxHp:0, day:'', defeated:false };
var BOSS_KEY = 'chitask_boss_v3';
var bossSpriteRaf = null;
var bossHitFlash = false;
var bossShaking = false;
var bossPhraseTimeout = null;

function bossLoad(){ try{ var r=JSON.parse(localStorage.getItem(BOSS_KEY)||'null'); if(r)bossState=r; }catch(e){} }
function bossSave(){ try{ localStorage.setItem(BOSS_KEY,JSON.stringify(bossState)); }catch(e){} }
function bossToday(){ var d=new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function bossCur(){ return BOSS_DEFS[bossState.idx]||BOSS_DEFS[0]; }

function bossInit(){
  bossLoad();
  var today = bossToday();
  if(bossState.day !== today){
    var idx = Math.floor(Math.random()*BOSS_DEFS.length);
    // HP multiplier: Mon=hard, Fri=medium, weekend=easy
    var mult = [0.85,1.2,1.0,1.0,1.0,0.9,0.8][new Date().getDay()];
    var maxHp = Math.round(BOSS_DEFS[idx].maxHp * mult);
    bossState = { idx:idx, hp:maxHp, maxHp:maxHp, day:today, defeated:false };
    bossSave();
  }
  bossBuildCard();
  bossRefresh();   // bossRefresh already calls bossApplyTheme
  bossStartLoop();
  bossTauntLoop();
}

function bossTauntLoop(){
  if(bossPhraseTimeout) clearTimeout(bossPhraseTimeout);
  bossPhraseTimeout = setTimeout(function(){
    if(!bossState.defeated) bossShowPhrase();
    bossTauntLoop();
  }, 8000 + Math.random()*12000);
}

function bossShowPhrase(){
  var b = bossCur();
  var el = document.getElementById('bossPhraseEl');
  if(!el) return;
  var b = bossCur();
  // ragePhrases diambil langsung dari def boss (tiap boss_*.js wajib mendefinisikannya)
  var ragePool = (b.ragePhrases && b.ragePhrases.length) ? b.ragePhrases
    : ['KAMU TIDAK AKAN MENANG!!','RAAAAHHH!!','TIDAK BISA DIKALAHKAN!!','BANGKIT LEBIH KUAT!!','JANGAN HARAP MENANG!!'];
  var pctNow = bossState.hp/bossState.maxHp;
  var phrases = pctNow < 0.3 ? ragePool : b.phrase;
  var txt = phrases[Math.floor(Math.random()*phrases.length)];
  el.textContent = '"' + txt + '"';
  el.style.opacity = '1';
  el.style.transform = 'translateY(0) scale(1)';
  setTimeout(function(){
    el.style.opacity = '0';
    el.style.transform = 'translateY(-6px) scale(0.95)';
  }, 2800);
}

// ── Sprite drawing ──
function bossStartLoop(){
  if(bossSpriteRaf) cancelAnimationFrame(bossSpriteRaf);
  var cvs = document.getElementById('bossSpriteCanvas');
  if(!cvs) return;
  function loop(){
    var b=bossCur();
    var pct=bossState.hp/bossState.maxHp;
    bossDrawSprite(cvs, b.id, pct, bossHitFlash, bossState.defeated);
    bossSpriteRaf=requestAnimationFrame(loop);
  }
  loop();
}

function bossDrawSprite(canvas, id, pct, flash, defeated){
  if(!canvas) return;
  var ctx = canvas.getContext('2d');
  var W=canvas.width, H=canvas.height;
  ctx.clearRect(0,0,W,H);
  ctx.imageSmoothingEnabled = false;
  var P = 4;
  ctx.save();
  // Canvas is 200x220. Center origin at (100,120):
  // Up: 120px = 30u — covers setan-distraksi (top=-30) ✓
  // Down: 100px = 25u — covers iblis-keraguan (bot=+23) ✓
  // Canvas displayed 1:1 at 200x220px CSS — all bosses same apparent size as original 160x160 canvas
  ctx.translate(W/2, H/2 + 10);

  // Raja & Master were designed for a smaller 120x120 canvas — scale them up so they
  // appear as large as the other bosses on the current 200x220 canvas.
  var _bossUpscale = { 'perfectus': 1.4, 'wacana': 1.4 };
  var _upscale = _bossUpscale[id] || 1.0;
  if (_upscale !== 1.0) ctx.scale(_upscale, _upscale);
  if(!defeated){
    var t = Date.now();
    var isLuckySprite = bossCur().id === 'lucky';
    if(isLuckySprite && pct<0.3){
      // Lucky hampir kenyang: happy bounce, bukan rage wobble
      var happyBounce = Math.abs(Math.sin(t/300)) * 2.5;
      var happySway   = Math.sin(t/600) * 0.8;
      ctx.translate(happySway, -happyBounce);
      // Sedikit scale up gembira (bukan mengancam)
      var joyScale = 1.0 + 0.03 * Math.abs(Math.sin(t/300));
      ctx.scale(joyScale, joyScale);
    } else {
      var wobble = Math.sin(t/480)*(pct<0.3?3.5:1.2);
      var sway   = Math.sin(t/900)*(pct<0.3?1.5:0.5);
      ctx.translate(sway, wobble);
      if(pct<0.3 && !flash){ ctx.scale(1.06,1.06); }
    }
  }
  if(flash){
    ctx.filter='brightness(12) saturate(0)';
  }
  bossPixelSprite(ctx, id, pct, defeated, P);
  ctx.restore();

  // Glow under sprite when raging
  if(!defeated && pct<0.3 && !flash){
    var b = bossCur();
    var glowCy = Math.max(8, H-8); // ensure positive y
    var r0 = Math.max(0, 2);       // inner radius must be >= 0
    var r1 = Math.max(r0+1, 28);   // outer radius must be > inner
    var grd = ctx.createRadialGradient(W/2,glowCy,r0,W/2,glowCy,r1);
    grd.addColorStop(0, b.col+'88');
    grd.addColorStop(1, 'transparent');
    ctx.globalAlpha=0.55+0.25*Math.sin(Date.now()/250);
    ctx.fillStyle=grd;
    ctx.fillRect(W/2-30,H-22,60,22);
    ctx.globalAlpha=1;
  }
}

// pixel block helper
function px(ctx,x,y,w,h,c,P){ ctx.fillStyle=c; ctx.fillRect(x*P,y*P,w*P,h*P); }

function bossPixelSprite(ctx, id, pct, defeated, P){
  var t = Date.now();

  // ── DEFEATED pose (shared) — tapi Lucky punya pose kenyang sendiri ──
  if(defeated && id !== 'lucky'){
    var dc='#374151', dg='#facc15', dw='#9ca3af', sk='#e5e7eb';
    [[-13,4,26,8,dc],[-12,3,24,6,dw],[-10,2,20,4,sk],
     [-8,-3,3,3,'#fff'],[-5,0,3,3,'#fff'],[-8,0,3,3,'#fff'],[-5,-3,3,3,'#fff'],
     [2,-3,3,3,'#fff'],[5,0,3,3,'#fff'],[2,0,3,3,'#fff'],[5,-3,3,3,'#fff'],
     [-4,4,2,2,dc],[-2,5,2,2,dc],[0,4,2,2,dc],[2,5,2,2,dc],[4,4,2,2,dc],
    ].forEach(function(r){ px(ctx,r[0],r[1],r[2],r[3],r[4],P); });
    var t=Date.now();
    [[-14,-5],[-10,-8],[-3,-9],[5,-7],[12,-5]].forEach(function(pos,i){
      var ang=t/600+i*1.26;
      var ox=Math.cos(ang)*3, oy=Math.sin(ang)*2;
      ctx.globalAlpha=0.6+0.4*Math.abs(Math.sin(t/400+i));
      ctx.fillStyle=dg; ctx.shadowColor=dg; ctx.shadowBlur=8;
      px(ctx,pos[0]+ox,pos[1]+oy,2,2,dg,P);
      ctx.shadowBlur=0; ctx.globalAlpha=1;
    });
    return;
  }

  // ── Delegate sprite drawing to per-boss sprite function ──
  var spriteFn = _bossSprites[id];
  if (spriteFn) {
    spriteFn(ctx, pct, defeated, P);
  } else {
    // Fallback: unknown boss — draw a simple question mark silhouette
    var dc = '#374151';
    ctx.globalAlpha = 0.7;
    ctx.font = 'bold ' + (10*P) + 'px monospace';
    ctx.fillStyle = '#9ca3af';
    ctx.textAlign = 'center';
    ctx.fillText('?', 0, 4*P);
    ctx.globalAlpha = 1;
    console.warn('[CT_Boss] No sprite registered for id:', id);
  }
}

// ── Attack Animation ──
var bossAttackRaf = null;
function bossAttackAnim(dmg){
  var panel = document.getElementById('bossBattlePanel');
  if(!panel) return;

  // 1. Sword slash canvas overlay
  var slashCvs = document.createElement('canvas');
  slashCvs.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:50;image-rendering:pixelated;border-radius:inherit;';
  slashCvs.width = panel.offsetWidth;
  slashCvs.height = panel.offsetHeight;
  panel.appendChild(slashCvs);
  var sctx = slashCvs.getContext('2d');
  var start = Date.now(), dur = 520;
  var W = slashCvs.width, H = slashCvs.height;

  function drawSlash(){
    var t = (Date.now()-start)/dur;
    sctx.clearRect(0,0,W,H);
    if(t >= 1){ slashCvs.remove(); return; }
    var progress = Math.min(t*2.6, 1);
    var alpha = t < 0.35 ? 1 : 1-(t-0.35)/0.65;
    var sx = W * (1 - progress * 1.35);
    var sy1 = H * 0.1, sy2 = H * 0.9;
    var colors = ['#ffffff','#ffff88','#ffdd00','#ff8800','#ff2200'];
    colors.forEach(function(col, ci){
      var off = ci * 5;
      sctx.globalAlpha = alpha * (1 - ci*0.18);
      sctx.strokeStyle = col;
      sctx.lineWidth = Math.max(1, (5-ci)*2.5);
      sctx.lineCap = 'round';
      sctx.beginPath();
      sctx.moveTo(sx+off+70, sy1-off);
      sctx.lineTo(sx-70+off, sy2+off);
      sctx.stroke();
    });
    sctx.globalAlpha = 1;

    // Impact sparks
    if(t > 0.08 && t < 0.52){
      var impX = sx + W*0.12;
      var impY = H*0.5;
      var sc = Math.floor((0.52-t)*24);
      for(var i=0;i<sc;i++){
        var ang = Math.random()*Math.PI*2;
        var dist = Math.random()*38*(t*2.2);
        var px2 = impX + Math.cos(ang)*dist;
        var py2 = impY + Math.sin(ang)*dist;
        var sz = (2+Math.random()*5)*2;
        sctx.fillStyle = ['#fff','#ffff00','#ff8800','#ff4444','#ffffff'][Math.floor(Math.random()*5)];
        sctx.globalAlpha = alpha*0.9;
        sctx.fillRect(Math.round(px2/2)*2, Math.round(py2/2)*2, sz, sz);
      }
      sctx.globalAlpha = 1;
    }
    requestAnimationFrame(drawSlash);
  }
  requestAnimationFrame(drawSlash);

  // 2. Hit flash
  bossHitFlash = true;
  var sprite = document.getElementById('bossSpriteCanvas');
  if(sprite){ sprite.style.filter='brightness(10) saturate(0) invert(1)'; }
  setTimeout(function(){ bossHitFlash=false; if(sprite) sprite.style.filter=''; }, 130);

  // 3. Shake the sprite area
  var sa = document.getElementById('bossSpriteArea');
  if(sa){ sa.classList.add('boss-shake'); }
  setTimeout(function(){ if(sa) sa.classList.remove('boss-shake'); }, 360);

  // 4. Blood drops
  bossBloodDrop(dmg);

  // 5. Damage number float
  bossDmgNum(dmg);
}

function bossBloodDrop(dmg){
  var area = document.getElementById('bossSpriteArea');
  if(!area) return;
  var count = Math.min(8, 3 + Math.floor(dmg/35));
  for(var i=0;i<count;i++){
    (function(i){
      setTimeout(function(){
        var drop = document.createElement('div');
        drop.className = 'boss-blood';
        drop.style.left = (15+Math.random()*70)+'%';
        drop.style.animationDuration = (0.55+Math.random()*0.55)+'s';
        drop.style.animationDelay = (Math.random()*0.15)+'s';
        var sz = (5+Math.random()*7)+'px';
        drop.style.width = sz; drop.style.height = sz;
        area.appendChild(drop);
        setTimeout(function(){ if(drop.parentNode) drop.parentNode.removeChild(drop); },900);
      }, i*35);
    })(i);
  }
}

function bossDmgNum(dmg){
  var panel = document.getElementById('bossBattlePanel');
  if(!panel) return;
  var num = document.createElement('div');
  num.className = 'boss-dmg-float';
  num.textContent = '-'+dmg;
  num.style.left = (15+Math.random()*35)+'%';
  panel.appendChild(num);
  setTimeout(function(){ if(num.parentNode) num.parentNode.removeChild(num); },1200);
}

// ── HP Bar update ──
function bossRefresh(){
  var b = bossCur();
  var pct = Math.max(0, bossState.hp/bossState.maxHp);
  var fill  = document.getElementById('bossHpFill');
  var nums  = document.getElementById('bossHpNums');
  var phase = document.getElementById('bossPhaseEl');
  var nameEl= document.getElementById('bossNameEl');
  var subEl = document.getElementById('bossSubEl');
  var panel = document.getElementById('bossBattlePanel');
  var aura  = document.getElementById('bossAuraEl');

  var isLuckyBar = b.id === 'lucky';
  var barCol;
  if(isLuckyBar){
    // Lucky: HP turun = makin kenyang = makin cerah & hijau
    barCol = pct>0.6 ? '#f97316' : pct>0.35 ? '#facc15' : pct>0.15 ? '#4ade80' : '#86efac';
  } else {
    barCol = pct>0.6?'#4ade80':pct>0.35?'#facc15':pct>0.15?'#f97316':'#ef4444';
  }
  if(fill){
    fill.style.width=(pct*100)+'%';
    fill.style.background='linear-gradient(90deg,'+barCol+','+barCol+'cc)';
    // Pulse on low HP (for Lucky: pulse when almost full/kenyang)
    fill.style.animation = pct < 0.25 ? 'bossHpPulse 0.6s ease infinite alternate' : 'none';
  }
  if(nums) nums.textContent = bossState.hp+' / '+bossState.maxHp;
  if(nameEl) nameEl.textContent = b.name;
  if(subEl)  subEl.textContent  = b.sub;
  if(phase){
    var isLucky = b.id === 'lucky';
    if(bossState.defeated){
      phase.textContent = isLucky ? '🍀 KENYANG TOTAL!' : '☠ DEFEATED';
      phase.style.color = '#4ade80';
    } else if(pct<0.15){
      phase.textContent = isLucky ? '😋 HAMPIR KENYANG!' : '💀 DYING...';
      phase.style.color = isLucky ? '#4ade80' : '#ef4444';
    } else if(pct<0.3){
      phase.textContent = isLucky ? '🤤 SEMAKIN LAHAP!' : '🔥 RAGE MODE';
      phase.style.color = isLucky ? '#86efac' : '#f97316';
    } else if(pct<0.5){
      phase.textContent = isLucky ? '😊 MULAI KENYANG' : '⚡ TERLUKA';
      phase.style.color = isLucky ? '#fde68a' : '#facc15';
    } else {
      phase.textContent = isLucky ? '🍽️ LAPAR BANGET' : '👹 SIAP TEMPUR';
      phase.style.color = isLucky ? '#facc15' : '#9ca3af';
    }
  }
  if(panel && !bossState.defeated){
    var isLuckyPanel = b.id === 'lucky';
    var rageGlow;
    if(isLuckyPanel && pct<0.3){
      // Lucky makin happy & bersinar emas saat hampir kenyang
      rageGlow = '0 0 32px rgba(250,204,21,0.8), 0 0 70px rgba(253,230,138,0.45), 0 0 120px rgba(250,204,21,0.25)';
    } else {
      rageGlow = pct<0.3 ? '0 0 32px rgba(239,68,68,0.6), 0 0 60px rgba(239,68,68,0.25)' : '0 0 24px '+b.aura+', 0 8px 40px rgba(0,0,0,0.8)';
    }
    panel.style.boxShadow = rageGlow;
    panel.style.borderColor = (isLuckyPanel && pct<0.3) ? '#fde68a' : (pct<0.3 ? '#ef4444' : b.col);
  }
  if(aura && !bossState.defeated){
    var isLuckyAura = b.id === 'lucky';
    if(isLuckyAura && pct<0.3){
      // Lucky: aura emas cerah makin kuat saat hampir kenyang
      aura.style.background = 'radial-gradient(ellipse at 50% 100%, rgba(250,204,21,0.55) 0%, rgba(253,230,138,0.2) 40%, transparent 70%)';
    } else {
      aura.style.background = pct<0.3
        ? 'radial-gradient(ellipse at 50% 100%, rgba(239,68,68,0.3) 0%, transparent 70%)'
        : 'radial-gradient(ellipse at 50% 100%, '+b.aura+' 0%, transparent 70%)';
    }
  }
  // Apply boss color theme to entire panel
  bossApplyTheme();
}

// ── Deal Damage (digantikan oleh toggleDone/toggleStep hooks di bawah) ──


// ══════════════════════════════════════════════
// 🎁 BOSS REWARD SYSTEM
// ══════════════════════════════════════════════
var _tempThemeTimer = null;

function bossRollReward(){
  var rand = Math.random();
  // 50% chance: tema yang BELUM dimiliki
  if(rand < 0.50){
    var allThemes = [
      {id:'theme-sololeveling', name:'Solo Leveling ⚔️', icon:'⚔️', glowColor:'#7c6af7'},
      {id:'theme-slytherin',    name:'Slytherin 🐍',     icon:'🐍', glowColor:'#2dbb5d'},
      {id:'theme-fluffytown',   name:'Fluffy Town 🐹',   icon:'🐹', glowColor:'#f472b6'},
      {id:'theme-midnight',     name:'Midnight 🌌',      icon:'🌌', glowColor:'#8b5cf6'},
      {id:'theme-sunset',       name:'Sunset 🌅',        icon:'🌅', glowColor:'#ea580c'}
    ];
    // Hanya tema yang belum dibeli di shop
    var avail = allThemes.filter(function(th){
      return typeof isOwned === 'function' ? !isOwned(th.id) : true;
    });
    if(avail.length > 0){
      var t = avail[Math.floor(Math.random()*avail.length)];
      // Random durasi: 1 jam (40%), 3 jam (35%), 6 jam (25%)
      var durationRoll = Math.random();
      var durHours, durMs, durLabel;
      if(durationRoll < 0.40){
        durHours = 1; durMs = 1 * 60 * 60 * 1000; durLabel = '1 jam';
      } else if(durationRoll < 0.75){
        durHours = 3; durMs = 3 * 60 * 60 * 1000; durLabel = '3 jam';
      } else {
        durHours = 6; durMs = 6 * 60 * 60 * 1000; durLabel = '6 jam';
      }
      return {type:'theme', themeId:t.id, themeName:t.name, themeIcon:t.icon,
              label:'Tema Sementara: '+t.name, desc:'Aktif selama '+durLabel+'!', icon:'🎨', glowColor:t.glowColor,
              durMs:durMs, durLabel:durLabel};
    }
    // Semua tema sudah dimiliki — lanjut ke gold/xp
  }
  // 50% sisanya: XP atau Gold
  var r2 = Math.random();
  if(r2 < 0.30){
    // 10-20 XP (prob 50% dalam pool ini → 30%*50%=15% overall sebelum normalize)
    var xpAmt = 10 + Math.floor(Math.random()*11);
    return {type:'xp', amount:xpAmt, label:'+'+xpAmt+' XP Bonus!', desc:'Hadiah dari boss', icon:'⚡', glowColor:'#60a5fa'};
  } else if(r2 < 0.65){
    // 5-10 XP
    var xpAmt2 = 5 + Math.floor(Math.random()*6);
    return {type:'xp', amount:xpAmt2, label:'+'+xpAmt2+' XP Bonus!', desc:'Hadiah dari boss', icon:'⚡', glowColor:'#60a5fa'};
  } else if(r2 < 0.80){
    // 10-20 Gold
    var gAmt = 10 + Math.floor(Math.random()*11);
    return {type:'gold', amount:gAmt, label:'+'+gAmt+' Gold!', desc:'Rampasan dari boss', icon:'🪙', glowColor:'#f59e0b'};
  } else if(r2 < 0.95){
    // 5-10 Gold
    var gAmt2 = 5 + Math.floor(Math.random()*6);
    return {type:'gold', amount:gAmt2, label:'+'+gAmt2+' Gold!', desc:'Rampasan dari boss', icon:'🪙', glowColor:'#f59e0b'};
  } else {
    // 1-5 Gold
    var gAmt3 = 1 + Math.floor(Math.random()*5);
    return {type:'gold', amount:gAmt3, label:'+'+gAmt3+' Gold!', desc:'Rampasan dari boss', icon:'🪙', glowColor:'#f59e0b'};
  }
}

function bossApplyReward(reward){
  if(reward.type==='xp'){
    addXP(reward.amount, '+'+reward.amount+' BOSS REWARD');
  } else if(reward.type==='gold'){
    addGold(reward.amount);
    showToast('🪙 +'+reward.amount+' gold dari boss!');
  } else if(reward.type==='theme'){
    // Bersihkan timer lama jika ada
    if(_tempThemeTimer) clearTimeout(_tempThemeTimer);
    // Simpan tema sebelumnya (hanya jika tidak sedang pakai tema sementara)
    if(tempThemeExpiry === 0) tempThemePrev = activeTheme || '';
    // Durasi random dari reward (default 1 jam jika tidak ada)
    var durMs = reward.durMs || (60 * 60 * 1000);
    var durLabel = reward.durLabel || '1 jam';
    // Catat expiry persisten ke localStorage
    tempThemeExpiry = Date.now() + durMs;
    // Terapkan tema baru sementara — set activeTheme DULU sebelum applyTheme
    activeTheme = reward.themeId;
    applyTheme(reward.themeId);
    // ✅ FIX: force re-render radar chart setelah activeTheme pasti sudah diset
    setTimeout(function(){
      if(typeof currentView !== 'undefined' && currentView === 'dashboard'){
        var el = document.getElementById('mainContent');
        if(el && typeof renderDashboard === 'function') renderDashboard(el);
      }
    }, 120);
    showToast('🎨 Tema '+reward.themeName+' aktif '+durLabel+'!');
    // Timer in-memory untuk sesi ini
    _tempThemeTimer = setTimeout(function(){
      _tempThemeTimer = null;
      activeTheme = tempThemePrev;
      tempThemeExpiry = 0;
      tempThemePrev = '';
      applyTheme(activeTheme);
      // ✅ FIX: force re-render radar chart saat tema sementara habis
      setTimeout(function(){
        if(typeof currentView !== 'undefined' && currentView === 'dashboard'){
          var el = document.getElementById('mainContent');
          if(el && typeof renderDashboard === 'function') renderDashboard(el);
        }
      }, 120);
      saveData();
      showToast('⏰ Tema sementara habis, kembali ke tema sebelumnya');
    }, durMs);
  }
  saveData();
}

function showBossChestAnimation(reward, onDone){
  var glowCol = reward.glowColor || '#f59e0b';

  var ov = document.createElement('div');
  ov.id  = 'bossChestOv';
  ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.40);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);z-index:9500;display:flex;align-items:center;justify-content:center;flex-direction:column;overflow:hidden;cursor:pointer;user-select:none;font-family:"Press Start 2P",monospace;';

  ov.innerHTML = `
    <style>
      @keyframes _bob  {
        0%,100%{ transform:translateY(0)   }
        50%    { transform:translateY(-10px) }
      }
      @keyframes _shk1 {
        0%,100%{ transform:translate(0,0) rotate(0deg) }
        20%    { transform:translate(-9px, 2px) rotate(-5deg) }
        50%    { transform:translate( 9px,-2px) rotate( 5deg) }
        80%    { transform:translate(-4px, 1px) rotate(-2deg) }
      }
      @keyframes _shk2 {
        0%,100%{ transform:translate(0,0) rotate(0deg) }
        10%    { transform:translate(-20px, 5px) rotate(-11deg) }
        25%    { transform:translate( 22px,-5px) rotate( 13deg) }
        40%    { transform:translate(-22px, 6px) rotate(-13deg) }
        55%    { transform:translate( 20px,-5px) rotate( 11deg) }
        70%    { transform:translate(-12px, 3px) rotate( -6deg) }
        85%    { transform:translate(  8px,-2px) rotate(  3deg) }
      }
      @keyframes _blink { 0%,100%{opacity:.28} 50%{opacity:.72} }
      #_cw  { display:flex;flex-direction:column;align-items:center;z-index:2 }
      #_svg { width:clamp(155px,30vw,255px);height:auto;display:block;
              animation:_bob 2.1s ease-in-out infinite;
              filter:drop-shadow(0 10px 28px rgba(0,0,0,.95)) drop-shadow(0 0 16px rgba(255,200,0,.28)) }
      #_ht  { font-size:clamp(7px,1.3vw,10px);color:rgba(255,255,255,.32);margin-top:24px;
              letter-spacing:2px;text-transform:uppercase;animation:_blink 1.6s ease infinite }
      #_rw  { display:none;flex-direction:column;align-items:center;z-index:2;
              padding:0 24px;opacity:0;transition:opacity .65s ease }
      #_ri  { font-size:clamp(58px,12vw,92px);line-height:1 }
      #_rl  { font-size:clamp(11px,3vw,22px);margin-top:16px;text-align:center;
              line-height:1.9;letter-spacing:2px }
      #_rd  { font-size:clamp(7px,1.3vw,10px);color:rgba(255,255,255,.5);margin-top:10px;
              text-align:center;line-height:2.2;letter-spacing:1px }
      @keyframes _rbpulse {
        0%,100%{ box-shadow:0 0 14px 3px var(--_gc,#f59e0b), 0 0 40px 8px var(--_gc,#f59e0b)44, 0 6px 24px rgba(0,0,0,.7) }
        50%    { box-shadow:0 0 36px 12px var(--_gc,#f59e0b), 0 0 70px 20px var(--_gc,#f59e0b)33, 0 6px 24px rgba(0,0,0,.7) }
      }
      @keyframes _rbshine {
        0%   { background-position: -200% center }
        100% { background-position:  300% center }
      }
      @keyframes _rbspark {
        0%,100%{ opacity:0; transform:translateX(-60px) skewX(-20deg) }
        10%,90%{ opacity:0 }
        45%    { opacity:.7; transform:translateX(0px)   skewX(-20deg) }
        55%    { opacity:.9; transform:translateX(20px)  skewX(-20deg) }
        80%    { opacity:0;  transform:translateX(120px) skewX(-20deg) }
      }
      #_rbwrap { position:relative; display:inline-block; margin-top:32px }
      #_rb  { display:block;padding:15px 52px;border:none;border-radius:50px;
              background: linear-gradient(105deg,
                var(--_gc,#f59e0b) 0%,
                #fff8 30%,
                var(--_gc,#f59e0b) 45%,
                var(--_gc2,#b45309) 70%,
                var(--_gc,#f59e0b) 100%);
              background-size:250% auto;
              font-family:"Press Start 2P",monospace;color:#1a0a00;
              font-size:clamp(7px,1.3vw,10px);cursor:pointer;letter-spacing:2px;
              text-transform:uppercase;font-weight:900;
              box-shadow:0 0 18px 4px var(--_gc,#f59e0b), 0 6px 24px rgba(0,0,0,.7);
              animation:_rbpulse 1.8s ease-in-out infinite, _rbshine 2.2s linear infinite;
              transition:transform .15s,filter .15s;
              outline:none; position:relative; overflow:hidden }
      #_rb::before {
              content:'';position:absolute;top:0;left:0;right:0;bottom:0;
              border-radius:50px;
              background:linear-gradient(105deg,transparent 30%,rgba(255,255,255,.55) 50%,transparent 70%);
              background-size:250% auto;
              animation:_rbspark 2.2s ease-in-out infinite;
              pointer-events:none }
      #_rb::after {
              content:'';position:absolute;inset:2px;border-radius:48px;
              border:1.5px solid rgba(255,255,255,.35);pointer-events:none }
      #_rb:hover  { transform:scale(1.08);filter:brightness(1.18) }
      #_rb:active { transform:scale(.95) }
    </style>

    <div id="_cw">
