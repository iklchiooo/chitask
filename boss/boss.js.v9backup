      <div id="_rbwrap"><button id="_rb">✦ KLAIM HADIAH ✦</button></div>
    </div>
  `;

  document.body.appendChild(ov);

  var svgEl    = ov.querySelector('#_svg');
  var hintEl   = ov.querySelector('#_ht');
  var wrapEl   = ov.querySelector('#_cw');
  var rwrapEl  = ov.querySelector('#_rw');
  var rIconEl  = ov.querySelector('#_ri');
  var rLblEl   = ov.querySelector('#_rl');
  var rDescEl  = ov.querySelector('#_rd');
  var claimBtn = ov.querySelector('#_rb');

  rLblEl.style.color       = glowCol;
  rLblEl.style.textShadow  = '0 0 18px ' + glowCol;
  claimBtn.style.color      = glowCol;
  claimBtn.style.borderColor = glowCol;

  // phase: 0=idle  1=after shake1  2=light spreading  3=revealed
  var phase = 0;
  var rafId  = null;

  function runShake(kf, ms, cb){
    svgEl.style.animation = 'none';
    void svgEl.offsetWidth;
    svgEl.style.animation = kf + ' ' + ms + 'ms ease both';
    if(cb) setTimeout(cb, ms);
  }

  // Cahaya dimulai dari titik kecil di tengah → menyebar penuh ke seluruh layar
  function startLight(){
    phase = 2;
    hintEl.style.display   = 'none';
    svgEl.style.animation  = 'none';

    var t0  = performance.now();
    var DUR = 5000; // ms — lambat di awal, akselerasi di akhir

    function frame(now){
      var raw  = Math.min((now - t0) / DUR, 1);
      // Smoothstep lalu ease-in-out: sangat lambat di awal, cepat di akhir
      var s    = raw * raw * (3 - 2 * raw);          // smoothstep
      var ease = s < .5 ? 2*s*s : 1 - Math.pow(-2*s+2, 2)/2;

      if(ease < .82){
        // ── FASE SPREAD: cahaya kecil di tengah, perlahan melebar ──
        var r      = Math.round(ease * 160);  // jari-jari cahaya 0→160%
        var inner  = Math.max(0, r - 10);
        var mid    = r + 12;
        var outer  = Math.min(220, r + 60);
        var dark   = (1 - ease).toFixed(3);
        ov.style.background =
          'radial-gradient(circle at center,' +
          glowCol       + ' 0%,' +
          glowCol       + ' ' + inner + '%,' +
          glowCol + 'bb ' + mid   + '%,' +
          glowCol + '33 ' + outer + '%,' +
          'rgba(0,0,0,' + dark + ') 100%)';
        svgEl.style.opacity = Math.max(0, 1 - ease * 2.2).toFixed(2);

      } else {
        // ── FASE PUNCAK: seluruh layar meledak penuh warna reward ──
        var p2 = (ease - .82) / .18;
        ov.style.background =
          'radial-gradient(circle at center,' +
          '#ffffff '      + Math.round(p2 * 40)         + '%,' +
          glowCol         + ' ' + Math.round(8  + p2*55) + '%,' +
          glowCol + 'cc ' + Math.round(50 + p2*32)       + '%,' +
          glowCol + '88 88%,' +
          glowCol + '44 100%)';
        svgEl.style.opacity = '0';

        if(p2 > .75 && phase === 2){
          phase = 3;
          if(rafId) cancelAnimationFrame(rafId);
          doReveal();
          return;
        }
      }

      if(raw < 1){ rafId = requestAnimationFrame(frame); }
      else if(phase === 2){ phase = 3; doReveal(); }
    }

    rafId = requestAnimationFrame(frame);
  }

  function doReveal(){
    wrapEl.style.display   = 'none';
    rIconEl.textContent    = reward.icon;
    rLblEl.textContent     = reward.label;
    rDescEl.textContent    = reward.desc;
    rwrapEl.style.display  = 'flex';
    // Set CSS vars for button gradient colors
    ov.style.setProperty('--_gc',  glowCol);
    // Derive a darker shade for gradient end
    ov.style.setProperty('--_gc2', glowCol + 'aa');
    // Background: hitam semi-transparan blur, tanpa warna reward
    ov.style.transition    = 'background 1s ease';
    ov.style.background    = 'rgba(0,0,0,0.40)';
    ov.style.backdropFilter = 'blur(12px)';
    ov.style.webkitBackdropFilter = 'blur(12px)';
    requestAnimationFrame(function(){ rwrapEl.style.opacity = '1'; });
  }

  ov.addEventListener('click', function(e){
    if(e.target === claimBtn) return;
    if(phase === 0){
      phase = 2;
      hintEl.style.display = 'none';
      svgEl.style.filter = 'drop-shadow(0 0 28px ' + glowCol + ') drop-shadow(0 0 55px #fff) brightness(2.3)';
      runShake('_shk2', 920, startLight);
    }
  });

  claimBtn.addEventListener('click', function(e){
    e.stopPropagation();
    if(rafId) cancelAnimationFrame(rafId);
    ov.remove();
    if(typeof onDone === 'function') onDone();
  });

  setTimeout(function(){
    if(phase === 3 && ov.parentNode){
      if(rafId) cancelAnimationFrame(rafId);
      ov.remove();
      if(typeof onDone === 'function') onDone();
    }
  }, 30000);
}


function bossVictory(){
  var b = bossCur();

  // If boss panel is minimized, restore it so user sees the victory —
  // regardless of whether they minimized it intentionally.
  // Only skip auto-restore if user minimized AND boss was NOT just defeated
  // (that case is impossible here since we only call bossVictory on defeat).
  if(_bossMinimized){
    _bossMinimized = false;
    _bossUserMinimized = false;
    var _vPanel = document.getElementById('bossBattlePanel');
    var _vTab   = document.getElementById('bossTab');
    if(_vPanel) _vPanel.classList.remove('boss-minimized');
    if(_vTab)   _vTab.style.display   = 'none';
    bossStartLoop();
    bossApplyTheme();
  }

  var ov = document.getElementById('bossVictoryOv');
  var msg = document.getElementById('bossVictoryMsg');
  if(ov){
    if(msg) msg.textContent = b.death;
    ov.style.display='flex';
    bossPixelBurst();
    setTimeout(function(){ ov.style.display='none'; },5500);
  }
  showToast('⚔️ BOSS DEFEATED! '+b.name+' dikalahkan!');

  // Roll & show reward chest setelah victory overlay selesai
  var reward = bossRollReward();
  setTimeout(function(){
    showBossChestAnimation(reward, function(){
      bossApplyReward(reward);
    });
  }, 5800);
}

function bossPixelBurst(){
  var cvs = document.getElementById('bossExpCvs');
  if(!cvs) return;
  var W=cvs.width=window.innerWidth, H=cvs.height=window.innerHeight;
  var ctx=cvs.getContext('2d');
  var b=bossCur();
  var cols=[b.col,b.glow,'#fff','#ffff00','#ff8800','#ff4444'];
  var pts=[];
  for(var i=0;i<130;i++) pts.push({x:W/2,y:H/2,vx:(Math.random()-0.5)*28,vy:(Math.random()-0.5)*28-5,sz:3+Math.floor(Math.random()*14),col:cols[Math.floor(Math.random()*cols.length)],life:1,dec:0.011+Math.random()*0.02,sq:Math.random()>0.4});
  var t0=Date.now();
  function frame(){
    ctx.clearRect(0,0,W,H);
    var alive=false;
    pts.forEach(function(p){ if(p.life<=0)return; alive=true; p.x+=p.vx;p.y+=p.vy;p.vy+=0.4;p.life-=p.dec; ctx.globalAlpha=Math.max(0,p.life); ctx.fillStyle=p.col; if(p.sq) ctx.fillRect(p.x,p.y,p.sz,p.sz); else ctx.fillRect(p.x,p.y,p.sz/2,p.sz); });
    ctx.globalAlpha=1;
    if(alive&&Date.now()-t0<5000) requestAnimationFrame(frame); else ctx.clearRect(0,0,W,H);
  }
  requestAnimationFrame(frame);
}

// ── Build the new RPG-style boss panel ──
function bossBuildCard(){
  var b = bossCur();

  var style = document.createElement('style');
  style.textContent = `
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

    /* ── boss-minimized: override body.gami-gamer !important di HTML ── */
    #bossBattlePanel.boss-minimized,
    body.gami-gamer #bossBattlePanel.boss-minimized { display: none !important; }
    #bossTab.boss-tab-force-hide    { display: none !important; }

    /* ══════════════════════════════════════════
       BOSS PANEL — desktop right, mobile bottom
    ══════════════════════════════════════════ */
    #bossBattlePanel {
      position: fixed;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 256px;
      background: linear-gradient(170deg, #0e0e18 0%, #14101e 60%, #0e0e18 100%);
      border: 2px solid #7c3aed;
      border-radius: 12px;
      z-index: 201;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      font-family: 'Press Start 2P', monospace;
      transition: border-color 0.4s, box-shadow 0.4s, top 0.15s, right 0.15s, background 0.4s,
                  opacity 0.35s cubic-bezier(0.4,0,0.2,1),
                  transform 0.35s cubic-bezier(0.4,0,0.2,1),
                  visibility 0s linear 0s;
      user-select: none;
      cursor: default;
      opacity: 1;
      visibility: visible;
    }
    /* Boss panel animating out (auto-minimize) — desktop: slide kiri, mobile override di bawah */
    #bossBattlePanel.boss-hiding {
      opacity: 0;
      transform: translateY(-50%) translateX(-30px) scale(0.93);
      visibility: hidden;
      transition: border-color 0.4s, box-shadow 0.4s, top 0.15s, right 0.15s, background 0.4s,
                  opacity 0.3s cubic-bezier(0.4,0,1,1),
                  transform 0.3s cubic-bezier(0.4,0,1,1),
                  visibility 0s linear 0.31s;
      pointer-events: none;
    }
    /* Boss tab — semua via CSS transition, tanpa animation keyframe agar tidak conflict */
    #bossTab {
      transition: transform 0.45s cubic-bezier(0.4,0,0.2,1),
                  opacity  0.3s  cubic-bezier(0.4,0,0.2,1),
                  background 0.3s, border-color 0.3s, box-shadow 0.3s, color 0.3s;
      /* state awal: tampak normal di bawah */
      opacity: 1;
      transform: translateY(0);
    }
    /* Tab tersembunyi — turun ke bawah + fade */
    #bossTab.boss-tab-hidden {
      opacity: 0;
      transform: translateY(30px);
      pointer-events: none;
    }
    /* Tab di posisi atas — translate ke atas */
    #bossTab.boss-tab-top {
      transform: translateY(var(--boss-tab-offset, 0px));
    }
    /* Tab di atas DAN tersembunyi (saat restore: turun dulu baru fade) */
    #bossTab.boss-tab-top.boss-tab-hidden {
      transform: translateY(calc(var(--boss-tab-offset, 0px) + 30px));
      opacity: 0;
    }
    /* Boss panel animating in (restore) */
    #bossBattlePanel.boss-showing {
      animation: bossPanelReveal 0.38s cubic-bezier(0.34,1.56,0.64,1) forwards;
    }
    @keyframes bossPanelReveal {
      from { opacity: 0; transform: translateY(-50%) translateX(-30px) scale(0.93); }
      to   { opacity: 1; transform: translateY(-50%) translateX(0)      scale(1);   }
    }

    /* drag handle cursor on header */
    #bossHeaderBar { cursor: grab; }
    #bossHeaderBar:active { cursor: grabbing; }

    /* ─ header ─ */
    #bossHeaderBar {
      background: linear-gradient(90deg, #1a0030, #0e001a, #1a0030);
      border-bottom: 1px solid rgba(124,58,237,0.35);
      padding: 6px 8px 6px 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
      flex-shrink: 0;
    }
    #bossHeaderTitle {
      font-size: 7px;
      color: #a855f7;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      flex: 1;
      pointer-events: none;
    }
    /* ── minimize button — always visible ── */
    #bossMinBtn {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.18);
      color: #9ca3af;
      cursor: pointer;
      font-size: 8px;
      line-height: 1;
      width: 20px;
      height: 20px;
      border-radius: 4px;
      font-family: 'Press Start 2P', monospace;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    #bossMinBtn:hover {
      background: rgba(255,255,255,0.14);
      color: #fff;
      border-color: rgba(255,255,255,0.4);
    }

    /* ─ sprite area ─ */
    #bossSpriteArea {
      position: relative;
      width: 100%;
      height: 220px;
      background: radial-gradient(ellipse at 50% 85%, rgba(88,28,135,0.5) 0%, #060010 70%);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    #bossSpriteArea::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
      background-size: 12px 12px;
      pointer-events: none;
    }
    #bossSpriteArea::after {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(0deg,rgba(0,0,0,0.1) 0px,rgba(0,0,0,0.1) 1px,transparent 1px,transparent 4px);
      pointer-events: none;
    }
    #bossAuraEl {
      position: absolute; bottom: 0; left: 0; right: 0; height: 55%;
      pointer-events: none; z-index: 1;
      transition: background 0.6s;
    }
    #bossSpriteCanvas { image-rendering: pixelated; position: relative; z-index: 2; width:200px; height:220px; }
    #bossPhraseEl {
      position: absolute; bottom: 5px; left: 5px; right: 5px;
      font-size: 8.5px; color: #ffffff; text-align: center;
      z-index: 10; opacity: 0;
      transform: translateY(4px) scale(0.95);
      transition: opacity 0.4s, transform 0.4s;
      line-height: 1.9; pointer-events: none; word-break: break-word;
      text-shadow:
        -1px -1px 0 #000,
         1px -1px 0 #000,
        -1px  1px 0 #000,
         1px  1px 0 #000,
         0 0 10px rgba(232,121,249,0.9),
         0 0 20px rgba(232,121,249,0.5);
      paint-order: stroke fill;
    }

    /* ─ info col ─ */
    #bossInfoCol {
      flex: 1; padding: 10px 12px 12px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .boss-name-row { display: flex; flex-direction: column; gap: 3px; }
    #bossNameEl {
      font-size: 8px; color: #fff; line-height: 1.6;
      text-shadow: 0 0 10px rgba(168,85,247,0.7);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    #bossSubEl { font-size: 7px; color: #c4b5fd; letter-spacing: 0.5px; }
    #bossPhaseEl { font-size: 6px; color: #9ca3af; letter-spacing: 0.5px; }
    .boss-hp-label-row { display: flex; justify-content: space-between; align-items: center; }
    .boss-hp-lbl { font-size: 6.5px; color: #9ca3af; letter-spacing: 0.5px; }
    #bossHpNums  { font-size: 6.5px; color: #d1d5db; }
    .boss-hp-track {
      height: 10px; background: #0a0a1a;
      border: 1px solid rgba(255,255,255,0.1); border-radius: 3px;
      overflow: hidden; position: relative;
    }
    #bossHpFill {
      height: 100%; width: 100%;
      background: linear-gradient(90deg, #4ade80, #4ade80cc);
      border-radius: 2px; position: relative;
      transition: width 0.45s cubic-bezier(0.4,0,0.2,1), background 0.5s;
    }
    #bossHpFill::after {
      content: ''; position: absolute;
      top: 2px; left: 2px; right: 2px; height: 2px;
      background: rgba(255,255,255,0.28); border-radius: 2px;
    }
    @keyframes bossHpPulse { from{opacity:1} to{opacity:0.5} }

    /* damage float */
    .boss-dmg-float {
      position: absolute; font-family: 'Press Start 2P', monospace;
      font-size: 16px; color: #ff4444;
      text-shadow: 2px 2px #000, 0 0 12px #f00, 0 0 24px #f006;
      pointer-events: none; z-index: 60; top: 22%;
      animation: bossDmgRise 1.2s ease-out forwards;
    }
    @keyframes bossDmgRise {
      0%   { opacity:1; transform:translateY(0) scale(1.2); }
      30%  { opacity:1; transform:translateY(-24px) scale(1.35); }
      100% { opacity:0; transform:translateY(-58px) scale(0.8); }
    }
    .boss-blood {
      position: absolute; top: 8%;
      border-radius: 50% 50% 60% 40%;
      background: radial-gradient(circle at 40% 30%, #ff6666, #cc0000);
      z-index: 5; animation: bossBloodFall linear forwards;
      box-shadow: 0 0 5px rgba(200,0,0,0.7);
    }
    @keyframes bossBloodFall {
      0%  { opacity:1; transform:translateY(0) scale(1); }
      70% { opacity:1; transform:translateY(62px) scale(0.88); }
      100%{ opacity:0; transform:translateY(75px) scale(0.65); }
    }
    .boss-shake { animation: bossShakeAnim 0.35s ease !important; }
    @keyframes bossShakeAnim {
      0%,100%{ transform:none; }
      15% { transform:translateX(-7px) rotate(-3deg); }
      35% { transform:translateX(7px) rotate(3deg); }
      55% { transform:translateX(-5px) rotate(-2deg); }
      75% { transform:translateX(5px) rotate(2deg); }
      90% { transform:translateX(-2px); }
    }
    @keyframes bossPanelPulse {
      0%,100%{ box-shadow:0 0 22px rgba(124,58,237,0.45),0 8px 40px rgba(0,0,0,0.85); }
      50%    { box-shadow:0 0 42px rgba(168,85,247,0.7),0 8px 40px rgba(0,0,0,0.85); }
    }
    #bossBattlePanel { animation: bossPanelPulse 3.5s ease infinite; }

    /* ── MINIMIZE TAB — bottom-right corner on desktop ── */
    #bossTab {
      position: fixed;
      bottom: 20px; right: 14px;
      background: linear-gradient(135deg, #14101e, #0e0e18);
      border: 2px solid #7c3aed;
      border-radius: 8px;
      padding: 8px 14px;
      display: flex; align-items: center; gap: 7px;
      font-family: 'Press Start 2P', monospace;
      font-size: 8px; color: #a855f7;
      cursor: pointer; z-index: 202;
      box-shadow: 0 0 14px rgba(124,58,237,0.5), 0 2px 8px rgba(0,0,0,0.6);
      white-space: nowrap;
      writing-mode: horizontal-tb !important;
      text-orientation: mixed !important;
      letter-spacing: 1px;
      transition: border-color 0.3s, box-shadow 0.3s, color 0.3s, background 0.3s, transform 0.42s cubic-bezier(0.34,1.56,0.64,1), opacity 0.25s ease;
    }
    #bossTab:hover { background: linear-gradient(135deg,#1c1430,#14101e); }
    #bossTab.boss-tab-top {
      transform: translateY(var(--boss-tab-offset, 0px));
    }
    #bossTabIcon { font-size: 12px; line-height:1; }
    @keyframes bossTabPulse {
      0%,100%{ box-shadow:0 0 10px rgba(124,58,237,0.45); }
      50%    { box-shadow:0 0 24px rgba(168,85,247,0.8); }
    }

    /* victory */
    #bossVictoryOv {
      position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9000;
      display:none;align-items:center;justify-content:center;
      flex-direction:column;gap:18px;
    }
    #bossVictoryOv h2 {
      font-family:'Press Start 2P',monospace;
      font-size:clamp(14px,3vw,26px);color:#facc15;text-align:center;
      text-shadow:0 0 30px #f59e0b,0 0 60px #f59e0b66;
      animation:bossVpulse 0.55s ease infinite alternate;
      max-width:80vw;line-height:2;
    }
    #bossVictoryMsg {
      font-family:'Press Start 2P',monospace;
      font-size:clamp(6px,1.5vw,11px);color:#fff;text-align:center;
      max-width:70vw;line-height:2.2;white-space:pre-line;
    }
    @keyframes bossVpulse{ from{transform:scale(1)} to{transform:scale(1.07)} }
    #bossExpCvs { position:fixed;inset:0;pointer-events:none;z-index:8999; }

    /* ── MOBILE ── */
    @media(max-width:700px){
      #bossBattlePanel {
        right:auto; top:auto; transform:none;
        bottom:70px; left:50%; transform:translateX(-50%);
        width:min(96vw,390px);
        flex-direction:row; border-radius:10px;
      }
      /* Mobile: fade ke kiri bawah (arah tab minimize di left:8px) */
      #bossBattlePanel.boss-hiding {
        transform: translateX(calc(-50% - 40px)) translateY(10px) scale(0.93);
      }
      @keyframes bossPanelReveal {
        from { opacity: 0; transform: translateX(calc(-50% - 40px)) translateY(10px) scale(0.93); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
      }
      #bossHeaderBar { display:none; }
      #bossSpriteArea {
        width:120px; min-width:120px; height:auto; min-height:132px;
        border-right:1px solid rgba(124,58,237,0.25);
        border-radius:0;
      }
      #bossSpriteCanvas { width:120px; height:132px; }
      #bossInfoCol { padding:8px 10px; gap:5px; }
      #bossNameEl  { font-size:9px; }
      #bossSubEl   { font-size:7px; display:block; }
      .boss-hp-track{ height:8px; }
      #bossPhraseEl { font-size:7.5px; bottom:3px; }
      /* mobile minimize button — top-right of panel */
      #bossMobileMinBtn {
        position:absolute; top:5px; right:7px;
        background:rgba(255,255,255,0.07);
        border:1px solid rgba(255,255,255,0.2);
        color:#9ca3af; cursor:pointer;
        font-size:7px; line-height:1;
        width:18px; height:18px;
        border-radius:3px;
        font-family:'Press Start 2P',monospace;
        display:flex; align-items:center; justify-content:center;
        z-index:10;
      }
      /* mobile tab — floating draggable ball */
      #bossTab {
        bottom: 120px; right: 16px; left: auto;
        width: 54px; height: 54px;
        padding: 0;
        border-radius: 50%;
        font-size: 0; gap: 0;
        flex-direction: column;
        align-items: center; justify-content: center;
        box-shadow: 0 4px 18px rgba(0,0,0,0.55), 0 0 16px rgba(124,58,237,0.6);
        touch-action: none;
        user-select: none;
        -webkit-user-select: none;
      }
      #bossTab span:not(#bossTabIcon) { display: none; }
      #bossTabIcon { font-size: 22px !important; line-height: 1; display: block; }
      .boss-tab-arrow { display: none !important; }
    }

    /* ── Side Drawer mode on mobile — ball handles position via JS drag ── */

    /* ── THEME OVERRIDES handled dynamically by bossApplyTheme() ── */
  `;
  document.head.appendChild(style);

  // ── Build panel HTML ──
  var panel = document.createElement('div');
  panel.id = 'bossBattlePanel';
  panel.innerHTML =
    '<div id="bossHeaderBar">' +
      '<span id="bossHeaderTitle">⚔ BOSS BATTLE</span>' +
      '<button id="bossMinBtn" onclick="bossMinimize()" title="Minimize">—</button>' +
    '</div>' +
    '<div id="bossSpriteArea">' +
      '<div id="bossAuraEl"></div>' +
      '<canvas id="bossSpriteCanvas" width="200" height="220"></canvas>' +
      '<div id="bossPhraseEl"></div>' +
    '</div>' +
    '<div id="bossInfoCol">' +
      '<div class="boss-name-row">' +
        '<span id="bossNameEl">...</span>' +
        '<span id="bossSubEl">...</span>' +
      '</div>' +
      '<span id="bossPhaseEl">👹 SIAP TEMPUR</span>' +
      '<div class="boss-hp-label-row">' +
        '<span class="boss-hp-lbl">❤ HP</span>' +
        '<span id="bossHpNums">0 / 0</span>' +
      '</div>' +
      '<div class="boss-hp-track"><div id="bossHpFill"></div></div>' +
    '</div>';
  document.body.appendChild(panel);

  // Mobile minimize button (outside header, absolute positioned)
  if(window.innerWidth <= 700){
    var mBtn = document.createElement('button');
    mBtn.id = 'bossMobileMinBtn';
    mBtn.textContent = '—';
    mBtn.title = 'Minimize';
    mBtn.onclick = bossMinimize;
    panel.appendChild(mBtn);
  }

  // ── Drag to reposition (desktop only) ──
  if(window.innerWidth > 700){
    var drag = { active:false, startX:0, startY:0, origRight:0, origTop:0 };
    var hdr  = document.getElementById('bossHeaderBar');
    hdr.addEventListener('mousedown', function(e){
      if(e.target.id==='bossMinBtn') return;
      drag.active  = true;
      drag.startX  = e.clientX;
      drag.startY  = e.clientY;
      var r  = panel.getBoundingClientRect();
      drag.origRight = window.innerWidth - r.right;
      drag.origTop   = r.top + r.height/2;
      panel.style.transition = 'none';
      panel.style.animation  = 'none';
      document.body.style.userSelect = 'none';
      e.preventDefault();
    });
    document.addEventListener('mousemove', function(e){
      if(!drag.active) return;
      var dx = e.clientX - drag.startX;
      var dy = e.clientY - drag.startY;
      var newRight = Math.max(0, Math.min(window.innerWidth - panel.offsetWidth, drag.origRight - dx));
      var newTop   = Math.max(panel.offsetHeight/2, Math.min(window.innerHeight - panel.offsetHeight/2, drag.origTop + dy));
      panel.style.right     = newRight + 'px';
      panel.style.top       = newTop   + 'px';
      panel.style.transform = 'translateY(-50%)';
    });
    document.addEventListener('mouseup', function(){
      if(!drag.active) return;
      drag.active = false;
      panel.style.transition = '';
      panel.style.animation  = '';
      document.body.style.userSelect = '';
    });
  }

  // ── Victory overlay ──
  var vov = document.createElement('div');
  vov.id = 'bossVictoryOv';
  vov.innerHTML =
    '<canvas id="bossExpCvs"></canvas>' +
    '<h2>⚔️ VICTORY! ⚔️</h2>' +
    '<p id="bossVictoryMsg"></p>' +
    '<p style="font-family:\'Press Start 2P\',monospace;font-size:6px;color:#6b7280;margin-top:6px">Boss baru muncul besok!</p>';
  document.body.appendChild(vov);
}

var _bossMinimized = false;
var _bossUserMinimized = false; // true only when user explicitly clicked minimize
function bossMinimize(){
  // Kalau ada auto-minimize aktif dan user klik tab, clear auto state dulu
  if(window._bossClearAutoMinimize) window._bossClearAutoMinimize();
  _bossMinimized = !_bossMinimized;
  _bossUserMinimized = _bossMinimized; // track user's explicit intent
  var panel = document.getElementById('bossBattlePanel');
  var tabEl = document.getElementById('bossTab');
  var btn   = document.getElementById('bossMinBtn');
  var mBtn  = document.getElementById('bossMobileMinBtn');

  if(_bossMinimized){
    // Hide panel
    if(panel) panel.classList.add('boss-minimized');
    if(bossSpriteRaf){ cancelAnimationFrame(bossSpriteRaf); bossSpriteRaf=null; }

    // Build tab if not yet exists
    if(!tabEl){
      tabEl = document.createElement('div');
      tabEl.id = 'bossTab';
      tabEl.onclick = bossMinimize;
      tabEl.title = 'Buka Boss Battle';
      document.body.appendChild(tabEl);
    }
    // Fill tab content with current boss info
    var b = bossCur();
    var pct = bossState.hp / bossState.maxHp;
    var phase = bossState.defeated ? (b.id==='lucky' ? '🍀' : '☠') : (b.id==='lucky' ? (pct<0.3?'🤤':pct<0.5?'😊':'🍽️') : (pct<0.3?'🔥':pct<0.5?'⚡':'⚔'));
    tabEl.innerHTML =
      '<span id="bossTabIcon">'+phase+'</span>' +
      '<span>' + b.name.split(' ').slice(0,2).join(' ') + '</span>';
    tabEl.classList.remove('boss-tab-top', 'boss-tab-hidden');
    tabEl.style.animation = '';
    tabEl.style.transition = '';
    tabEl.style.display = 'flex';
    // Reset _swipeBound agar swipe listener + tombol arrow di-rebind ulang
    // (innerHTML di-wipe di atas, jadi arrow span hilang dan harus dibuat ulang)
    tabEl._swipeBound = false;
    bossApplyTheme();
    if(typeof _bossTabBindSwipe === 'function') _bossTabBindSwipe(tabEl);
    if(typeof window._bossTabRebindScroll === 'function') window._bossTabRebindScroll();

  } else {
    // Restore panel dengan animasi smooth
    _bossUserMinimized = false;
    if(typeof window._bossForceResetAnim === 'function') window._bossForceResetAnim();

    function _doRestorePanel(){
      // Sembunyikan tab dulu dengan fade
      if(tabEl){
        tabEl.style.transition = '';
        tabEl.classList.add('boss-tab-hidden'); // fade out + slide turun
      }
      // Setelah tab fade out (~300ms), tampilkan panel dengan boss-showing
      setTimeout(function(){
        if(tabEl){
          tabEl.style.display = 'none';
          tabEl.classList.remove('boss-tab-top', 'boss-tab-hidden');
          tabEl.style.animation = '';
          tabEl.style.transition = '';
        }
        if(panel){
          panel.classList.remove('boss-hiding', 'boss-showing');
          panel.classList.remove('boss-minimized');
          void panel.offsetWidth; // reflow agar animasi mulai dari awal
          panel.classList.add('boss-showing');
          setTimeout(function(){ panel.classList.remove('boss-showing'); }, 420);
        }
        if(typeof window._bossTabRebindScroll === 'function') window._bossTabRebindScroll();
        bossStartLoop();
        bossApplyTheme();
      }, 300);
    }

    // Kalau tab sedang di atas, slide turun dulu baru restore panel
    if(tabEl && typeof window._bossResetTabTop === 'function' && tabEl.classList.contains('boss-tab-top')){
      tabEl.classList.remove('boss-tab-top'); // slide turun smooth (~450ms)
      setTimeout(_doRestorePanel, 200); // mulai fade tab sedikit sebelum slide selesai agar mulus
    } else {
      if(typeof window._bossResetTabTop === 'function') window._bossResetTabTop();
      _doRestorePanel();
    }
  }
}

// ── Auto-minimize boss saat scroll mentok bawah, restore saat scroll naik ──
(function(){
  var _bossTabScrollBound = false;
  window._bossTabAtTop = false; var _bossTabAtTop = window._bossTabAtTop = false
  var _bossAutoMinimized  = false;
  var _bossAnimating      = false; // guard: jangan trigger ulang saat animasi berjalan
  var _bossBoundScrollEl  = null; // elemen scroll yang sedang di-listen

  // Deteksi scroll container aktif berdasarkan currentView
  function _bossGetScrollContainer(){
    var cv = (typeof currentView !== 'undefined') ? currentView : 'myday';
    // Fin views: pakai finScroll (inner) atau finWrap
    if(typeof isFinView === 'function' && isFinView(cv)){
      return document.getElementById('finScroll') || document.getElementById('finWrap');
    }
    // Maint views: finWrap dipakai sebagai container flex column, cari inner scroll
    if(typeof isMaintView === 'function' && isMaintView(cv)){
      var fw = document.getElementById('finWrap');
      if(fw){
        var inner = fw.querySelector('[style*="overflow-y:auto"],[style*="overflow-y: auto"]');
        if(inner) return inner;
      }
      return fw;
    }
    // Semua view lain (task, journal, calendar, dashboard, dll) pakai taskScroll
    return document.getElementById('taskScroll');
  }

  function _bossTabComputeOffset(tabEl){
    var isMobile = window.innerWidth <= 700;
    var isSidebarMode = isMobile && document.body.classList.contains('mobile-nav-sidebar');
    var tabBottom = isMobile && !isSidebarMode ? 70 : 20;
    var tabH = tabEl.offsetHeight || 36;
    var tabTopEdge = window.innerHeight - tabBottom - tabH;
    var targetTop;
    if(isSidebarMode){
      var sqaEl = document.getElementById('sidebarQuickAdd');
      if(sqaEl && sqaEl.offsetParent !== null && sqaEl.style.display !== 'none'){
        targetTop = sqaEl.getBoundingClientRect().bottom + 10;
      } else {
        var tb = document.querySelector('.topbar');
        targetTop = tb ? tb.getBoundingClientRect().bottom + 10 : 80;
      }
    } else {
      var tb2 = document.querySelector('.topbar');
      targetTop = tb2 ? tb2.getBoundingClientRect().bottom + 10 : (isMobile ? 80 : 70);
    }
    return targetTop - tabTopEdge;
  }
  window._bossTabComputeOffset = _bossTabComputeOffset; // expose untuk swipe handler

  function _bossDoAutoMinimize(){
    if(_bossMinimized || _bossUserMinimized || _bossAnimating) return;
    _bossAutoMinimized = true;
    _bossMinimized = true;
    _bossAnimating = true;

    var panel = document.getElementById('bossBattlePanel');

    // Siapkan tab — set ke state tersembunyi (tanpa transition) dulu
    var tabEl = document.getElementById('bossTab');
    if(!tabEl){
      tabEl = document.createElement('div');
      tabEl.id = 'bossTab';
      tabEl.onclick = bossMinimize;
      tabEl.title = 'Buka Boss Battle';
      document.body.appendChild(tabEl);
    }
    var b = bossCur();
    var pct = bossState.hp / bossState.maxHp;
    var phase = bossState.defeated ? (b.id==='lucky' ? '🍀' : '☠') : (b.id==='lucky' ? (pct<0.3?'🤤':pct<0.5?'😊':'🍽️') : (pct<0.3?'🔥':pct<0.5?'⚡':'⚔'));
    tabEl.innerHTML = '<span id="bossTabIcon">'+phase+'</span><span>'+b.name.split(' ').slice(0,2).join(' ')+'</span>';
    tabEl.style.animation = '';
    tabEl.style.transition = 'none'; // nonaktifkan transition sementara
    tabEl.classList.remove('boss-tab-top');
    tabEl.classList.add('boss-tab-hidden'); // posisi bawah + opacity 0, tanpa animasi
    tabEl.style.display = 'flex';
    bossApplyTheme();
    if(typeof _bossTabBindSwipe === 'function') _bossTabBindSwipe(tabEl);

    // Step 1: Panel fade+slide ke kiri
    if(panel){
      panel.classList.remove('boss-showing');
      panel.classList.add('boss-hiding');
      // Setelah animasi hiding selesai (~310ms), set display:none agar state konsisten
      setTimeout(function(){ if(panel) panel.classList.add('boss-minimized'); }, 320);
    }

    // Step 2: Setelah panel hilang (~310ms) → tab muncul naik dari bawah
    setTimeout(function(){
      if(bossSpriteRaf){ cancelAnimationFrame(bossSpriteRaf); bossSpriteRaf = null; }
      // Aktifkan transition, reflow, lalu hapus hidden → tab naik muncul dari bawah
      tabEl.style.transition = '';
      void tabEl.offsetWidth;
      tabEl.classList.remove('boss-tab-hidden'); // translateY(30px)+opacity:0 → translateY(0)+opacity:1

      // Step 3: Tunggu transition naik selesai dulu (450ms) → BARU slide ke atas
      setTimeout(function(){
        var sc = _bossGetScrollContainer();
        var stillAtBottom = sc && (sc.scrollHeight - sc.scrollTop - sc.clientHeight) < 60;
        if(stillAtBottom && !_bossTabAtTop){
          _bossTabAtTop = window._bossTabAtTop = true
          var offset = _bossTabComputeOffset(tabEl);
          tabEl.style.setProperty('--boss-tab-offset', offset + 'px');
          // Sedikit delay lagi agar browser commit dulu state translateY(0) sebelum naik
          void tabEl.offsetWidth;
          tabEl.classList.add('boss-tab-top'); // translateY(0) → translateY(offset) smooth
          var _arr = tabEl.querySelector('.boss-tab-arrow');
          if(_arr) _arr.textContent = '▼'; // tab sedang di atas → bisa turun
        }
        if(typeof window._bossTabRebindScroll === 'function') window._bossTabRebindScroll();
        setTimeout(function(){ _bossAnimating = false; }, 480);
      }, 470); // harus lebih dari transition duration (450ms)
    }, 310);
  }

  function _bossDoAutoRestore(){
    if(!_bossAutoMinimized || _bossAnimating) return;
    _bossAutoMinimized = false;
    _bossMinimized = false;
    _bossAnimating = true;

    var panel = document.getElementById('bossBattlePanel');
    var tabEl  = document.getElementById('bossTab');

    function _showPanel(){
      if(tabEl){
        tabEl.style.transition = 'none';
        tabEl.classList.add('boss-tab-hidden');
        tabEl.classList.remove('boss-tab-top');
        tabEl.style.display = 'none';
        tabEl.style.transition = '';
      }
      if(panel){
        panel.classList.remove('boss-hiding');
        panel.classList.add('boss-showing');
        panel.classList.remove('boss-minimized');
        setTimeout(function(){
          panel.classList.remove('boss-showing');
          _bossAnimating = false;
        }, 420);
      } else {
        _bossAnimating = false;
      }
      bossStartLoop();
      bossApplyTheme();
    }

    if(tabEl && tabEl.style.display !== 'none'){
      if(_bossTabAtTop){
        // Tab di atas → slide turun ke posisi normal dulu via CSS transition
        _bossTabAtTop = window._bossTabAtTop = false
        tabEl.classList.remove('boss-tab-top'); // translateY(offset) → translateY(0) smooth
        // Setelah transition turun selesai (~450ms) → fade out ke bawah
        setTimeout(function(){
          void tabEl.offsetWidth;
          tabEl.classList.add('boss-tab-hidden'); // opacity:1 → 0, slide turun 30px
          setTimeout(_showPanel, 320);
        }, 460);
      } else {
        // Tab sudah di bawah → langsung fade out
        tabEl.classList.add('boss-tab-hidden');
        setTimeout(_showPanel, 320);
      }
    } else {
      _showPanel();
    }
  }

  var _bossScrollDebounce = null;
  function _bossTabCheckScroll(){
    clearTimeout(_bossScrollDebounce);
    _bossScrollDebounce = setTimeout(function(){
      if(_bossAnimating) return; // jangan interrupt animasi yang sedang berjalan
      var sc = _bossGetScrollContainer();
      if(!sc) return;
      var atBottom = (sc.scrollHeight - sc.scrollTop - sc.clientHeight) < 60;

      if(atBottom){
        // Scroll mentok bawah
        if(!_bossMinimized && !_bossUserMinimized){
          // Boss masih tampil & user belum minimize → auto-minimize
          _bossDoAutoMinimize();
        }
        // Kalau sudah minimize (manual atau auto), pindah tab ke atas
        if(_bossMinimized && !_bossTabAtTop){
          var tabEl = document.getElementById('bossTab');
          if(tabEl && tabEl.style.display !== 'none'){
            _bossTabAtTop = window._bossTabAtTop = true
            var offset = _bossTabComputeOffset(tabEl);
            tabEl.style.setProperty('--boss-tab-offset', offset + 'px');
            tabEl.classList.add('boss-tab-top');
            var _arrSc = tabEl.querySelector('.boss-tab-arrow');
            if(_arrSc) _arrSc.textContent = '▼';
          }
        }
      } else {
        // Scroll tidak di bawah lagi
        if(_bossAutoMinimized){
          // Kita yang minimize → restore boss
          _bossDoAutoRestore();
          _bossTabAtTop = window._bossTabAtTop = false
        } else if(_bossMinimized && _bossTabAtTop){
          // User minimize manual → cukup turunkan tab kembali
          var tabEl2 = document.getElementById('bossTab');
          if(tabEl2) tabEl2.classList.remove('boss-tab-top');
          var _arrD = tabEl2 && tabEl2.querySelector('.boss-tab-arrow');
          if(_arrD) _arrD.textContent = '▲';
          _bossTabAtTop = window._bossTabAtTop = false
        }
      }
    }, 80);
  }

  function _bossBindScrollIfNeeded(){
    var sc = _bossGetScrollContainer();
    if(!sc) return;
    // Jika sudah bind ke elemen yang sama, skip
    if(_bossTabScrollBound && _bossBoundScrollEl === sc) return;
    // Lepas listener dari elemen lama
    if(_bossBoundScrollEl && _bossBoundScrollEl !== sc){
      _bossBoundScrollEl.removeEventListener('scroll', _bossTabCheckScroll);
    }
    sc.addEventListener('scroll', _bossTabCheckScroll, {passive:true});
    _bossBoundScrollEl = sc;
    _bossTabScrollBound = true;
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', _bossBindScrollIfNeeded);
  } else {
    setTimeout(_bossBindScrollIfNeeded, 800);
  }
  window._bossTabRebindScroll = function(){
    _bossTabScrollBound = false;
    _bossTabAtTop = window._bossTabAtTop = false
    setTimeout(_bossBindScrollIfNeeded, 200);
  };
  // Reset auto state saat view berganti
  window._bossScrollResetAuto = function(){
    if(_bossAutoMinimized) _bossDoAutoRestore();
    // ✅ FIX: saat ganti view, turunkan tab boss ke bawah dengan smooth
    // _bossTabRebindScroll TIDAK boleh melakukan ini (dipanggil juga di konteks lain)
    // jadi reset DOM class dilakukan di sini, khusus untuk view-switch
    var tabEl = document.getElementById('bossTab');
    if(tabEl && _bossTabAtTop){
      tabEl.classList.remove('boss-tab-top'); // CSS transition: slide down ~450ms
      var _arrow = tabEl.querySelector('.boss-tab-arrow');
      if(_arrow) _arrow.textContent = '▲'; // reset ke ▲
      // Tunda rebind scroll hingga slide-down selesai, agar scroll-check
      // tidak langsung memicu naik lagi di view baru
      _bossTabAtTop = window._bossTabAtTop = false
      setTimeout(function(){
        if(typeof window._bossTabRebindScroll === 'function') window._bossTabRebindScroll();
      }, 500);
    } else {
      _bossTabAtTop = window._bossTabAtTop = false
    }
  };
  // Clear auto flag saja (tanpa restore) — dipanggil saat user klik tab manual
  window._bossClearAutoMinimize = function(){
    _bossAutoMinimized = false;
  };
  // Reset posisi tab ke bawah — dipanggil dari bossMinimize saat user restore
  window._bossResetTabTop = function(){
    if(_bossTabAtTop){
      var tabEl = document.getElementById('bossTab');
      if(tabEl) tabEl.classList.remove('boss-tab-top');
      _bossTabAtTop = window._bossTabAtTop = false
    }
  };
  // Force reset animating flag — dipanggil saat user override animasi yang sedang berjalan
  window._bossForceResetAnim = function(){
    _bossAnimating = false;
    _bossAutoMinimized = false;
  };
})();
// ── Boss Tab Swipe Up/Down untuk toggle posisi atas/bawah ──
function _bossTabToggleTop(tabEl, goTop){
  if(!tabEl) return;
  if(goTop){
    if(window._bossTabAtTop) return;
    window._bossTabAtTop = true;
    var offset = (typeof window._bossTabComputeOffset === 'function')
      ? window._bossTabComputeOffset(tabEl) : -200;
    tabEl.style.setProperty('--boss-tab-offset', offset + 'px');
    void tabEl.offsetWidth;
    tabEl.classList.add('boss-tab-top');
  } else {
    if(!window._bossTabAtTop) return;
    window._bossTabAtTop = false;
    tabEl.classList.remove('boss-tab-top');
  }
  // Update arrow button label
  var arrowBtn = tabEl.querySelector('.boss-tab-arrow');
  if(arrowBtn) arrowBtn.textContent = window._bossTabAtTop ? '▼' : '▲';
}

function _bossTabBindSwipe(tabEl){\
  if(!tabEl || tabEl._swipeBound) return;\
  tabEl._swipeBound = true;\
\
  // ── Desktop: tambah tombol arrow toggle posisi ──\
  var isMobile = window.innerWidth <= 700;\
  if(!isMobile){\
    if(!tabEl.querySelector('.boss-tab-arrow')){\
      var arrowBtn = document.createElement('span');\
      arrowBtn.className = 'boss-tab-arrow';\
      arrowBtn.textContent = '▲';\
      arrowBtn.style.cssText = 'font-size:8px;opacity:0.6;margin-left:4px;cursor:pointer;padding:2px 3px;line-height:1;-webkit-tap-highlight-color:transparent';\
      arrowBtn.addEventListener('click', function(e){\
        e.stopPropagation();\
        _bossTabToggleTop(tabEl, !window._bossTabAtTop);\
      });\
      tabEl.appendChild(arrowBtn);\
    }\
\
    var _sy = 0, _sx = 0, _moved = false, _isVertical = false;\
    tabEl.addEventListener('touchstart', function(e){\
      _sy = e.touches[0].clientY; _sx = e.touches[0].clientX;\
      _moved = false; _isVertical = false;\
    }, {passive: true});\
    tabEl.addEventListener('touchmove', function(e){\
      var dx = Math.abs(e.touches[0].clientX - _sx);\
      var dy = Math.abs(e.touches[0].clientY - _sy);\
      if(dx > 6 || dy > 6){ _moved = true; _isVertical = dy > dx * 0.8; }\
      if(_isVertical) e.preventDefault();\
    }, {passive: false});\
    tabEl.addEventListener('touchend', function(e){\
      if(!_moved) return;\
      var dy = e.changedTouches[0].clientY - _sy;\
      var adx = Math.abs(e.changedTouches[0].clientX - _sx);\
      var ady = Math.abs(dy);\
      if(ady < 20 || adx > ady * 0.8) return;\
      e.preventDefault(); e.stopPropagation();\
      _bossTabToggleTop(tabEl, dy < 0);\
    }, {passive: false});\
    return;\
  }\
\
  // ── Mobile: floating draggable ball ──\
  var BALL = 54; // diameter px\
  var EDGE = 10; // margin from screen edge\
  var vw = window.innerWidth;\
  var vh = window.innerHeight;\
  var _drag = { active: false, startX: 0, startY: 0, origLeft: 0, origTop: 0, moved: false };\
\
  // Set initial position (bottom-right)\
  tabEl.style.left   = (vw - BALL - EDGE) + 'px';\
  tabEl.style.top    = (vh - BALL - 120) + 'px';\
  tabEl.style.right  = 'auto';\
  tabEl.style.bottom = 'auto';\
  tabEl.style.position = 'fixed';\
\
  function _clamp(val, min, max){ return Math.max(min, Math.min(max, val)); }\
\
  function _snapToEdge(){\
    var vw2 = window.innerWidth, vh2 = window.innerHeight;\
    var left = parseFloat(tabEl.style.left) || 0;\
    var top  = parseFloat(tabEl.style.top)  || 0;\
    // Snap to nearest vertical edge\
    var snapLeft = left + BALL/2 < vw2/2 ? EDGE : vw2 - BALL - EDGE;\
    tabEl.style.transition = 'left 0.28s cubic-bezier(0.34,1.4,0.64,1), top 0.18s ease';\
    tabEl.style.left = snapLeft + 'px';\
    tabEl.style.top  = _clamp(top, EDGE, vh2 - BALL - EDGE) + 'px';\
    setTimeout(function(){ tabEl.style.transition = ''; }, 320);\
  }\
\
  tabEl.addEventListener('touchstart', function(e){\
    var t = e.touches[0];\
    _drag.active  = true;\
    _drag.moved   = false;\
    _drag.startX  = t.clientX;\
    _drag.startY  = t.clientY;\
    _drag.origLeft = parseFloat(tabEl.style.left) || 0;\
    _drag.origTop  = parseFloat(tabEl.style.top)  || 0;\
    tabEl.style.transition = 'none';\
    tabEl.style.transform = 'scale(1.12)';\
    e.stopPropagation();\
  }, {passive: true});\
\
  tabEl.addEventListener('touchmove', function(e){\
    if(!_drag.active) return;\
    var t = e.touches[0];\
    var dx = t.clientX - _drag.startX;\
    var dy = t.clientY - _drag.startY;\
    if(Math.abs(dx) > 5 || Math.abs(dy) > 5) _drag.moved = true;\
    if(_drag.moved){\
      var vw2 = window.innerWidth, vh2 = window.innerHeight;\
      tabEl.style.left = _clamp(_drag.origLeft + dx, EDGE, vw2 - BALL - EDGE) + 'px';\
      tabEl.style.top  = _clamp(_drag.origTop  + dy, EDGE, vh2 - BALL - EDGE) + 'px';\
      e.preventDefault();\
    }\
  }, {passive: false});\
\
  tabEl.addEventListener('touchend', function(e){\
    if(!_drag.active) return;\
    _drag.active = false;\
    tabEl.style.transform = '';\
    if(_drag.moved){\
      _snapToEdge();\
    }\
    // Tap (no significant move) → buka panel\
    // handled by onclick on tabEl\
  }, {passive: true});\
}



// ── Flash damage on minimized boss, then re-minimize ──
function _bossFlashDamageIfMinimized(dmg, onDone){
  if(!_bossMinimized){
    // Panel visible normally
    bossAttackAnim(dmg);
    if(onDone) setTimeout(onDone, 600);
    return;
  }
  // Boss is minimized by user — temporarily show it, play attack, then re-minimize
  var panel = document.getElementById('bossBattlePanel');
  var tabEl  = document.getElementById('bossTab');

  // First: briefly flash the tab to signal something happened
  if(tabEl){
    tabEl.style.transition = 'transform 0.08s, box-shadow 0.08s, background 0.12s';
    tabEl.style.transform = 'scale(1.15)';
    tabEl.style.boxShadow = '0 0 28px #ff4444, 0 0 50px #ff000055';
    tabEl.style.background = 'linear-gradient(135deg,#3b0000,#1a0000)';
    setTimeout(function(){
      if(tabEl){
        tabEl.style.transform = '';
        tabEl.style.boxShadow = '';
        tabEl.style.background = '';
        tabEl.style.transition = '';
      }
    }, 350);
  }

  // Show panel
  if(panel) panel.classList.remove('boss-minimized');
  if(tabEl) tabEl.style.display = 'none';
  bossStartLoop();
  bossApplyTheme();
  // Play attack animation
  setTimeout(function(){
    bossAttackAnim(dmg);
    // Update tab content after damage
    if(tabEl){
      var b2 = bossCur();
      var pct2 = bossState.hp / bossState.maxHp;
      var ph2 = bossState.defeated ? (b2.id==='lucky' ? '🍀' : '☠') : (b2.id==='lucky' ? (pct2<0.3?'🤤':pct2<0.5?'😊':'🍽️') : (pct2<0.3?'🔥':pct2<0.5?'⚡':'⚔'));
      tabEl.innerHTML = '<span id="bossTabIcon">'+ph2+'</span><span>'+b2.name.split(' ').slice(0,2).join(' ')+'</span>';
    }
    // After animation finishes, re-minimize (user preference preserved)
    setTimeout(function(){
      if(_bossMinimized){
        if(panel) panel.classList.add('boss-minimized');
        if(bossSpriteRaf){ cancelAnimationFrame(bossSpriteRaf); bossSpriteRaf = null; }
        if(tabEl) tabEl.style.display = 'flex';
        bossApplyTheme();
      }
      if(onDone) onDone();
    }, 900);
  }, 80);
}

// ── Hook toggleDone — task tanpa langkah: damage 70-120 langsung ──
var _origToggleDone = toggleDone;
toggleDone = function(id){
  var tBefore = tasks.filter(function(x){ return x.id===id; })[0];
  var wasDone = tBefore ? tBefore.done : false;
  // Task due masa depan: toggleDone akan bail out tanpa mengubah state
  if(tBefore && !wasDone && tBefore.due && tBefore.due > todayStr) return _origToggleDone(id);
  _origToggleDone(id);
  var tAfter = tasks.filter(function(x){ return x.id===id; })[0];
  if(!tAfter || bossState.defeated) return;
  // Lucky Amstow punya mekanisme sendiri (makan), skip slash
  if(bossCur().id === 'lucky') return;
  var wasJustCompleted = !wasDone && (tAfter.done || tAfter._nextDue !== undefined);
  if(wasJustCompleted && !(tAfter.steps && tAfter.steps >= 2)){
    setTimeout(function(){
      if(bossState.defeated) return;
      if(bossCur().id === 'lucky') return;
      var dmg = 70 + Math.floor(Math.random()*51);
      bossState.hp = Math.max(0, bossState.hp - dmg);
      if(bossState.hp === 0 && !bossState.defeated){
        bossState.defeated = true;
        bossSave(); bossRefresh();
        _bossFlashDamageIfMinimized(dmg, function(){ bossVictory(); });
        return;
      }
      bossSave(); bossRefresh();
      _bossFlashDamageIfMinimized(dmg);
    }, 150);
  }
};

// ── Hook toggleDone — Sholat Jumat selesai → sync streak Dzuhur ──
var _origToggleDone2 = toggleDone;
toggleDone = function(id) {
  _origToggleDone2(id);
  // Cek apakah task yang baru diselesaikan adalah Sholat Jumat
  var t = tasks.filter(function(x){ return x.id === id; })[0];
  if (!t) return;
  if (t.name !== '🕌 Sholat Jumat') return;
  // Cari task Dzuhur
  var dzuhurName2 = '';
  if (typeof SHOLAT_NAMES !== 'undefined' && typeof SHOLAT_ICONS !== 'undefined') {
    var idx2 = SHOLAT_NAMES.indexOf('Dzuhur');
    if (idx2 >= 0) dzuhurName2 = SHOLAT_ICONS[idx2] + ' Sholat Dzuhur';
  }
  if (!dzuhurName2) return;
  var dzuhur2 = tasks.filter(function(x){ return x.name === dzuhurName2; })[0];
  if (!dzuhur2 || !dzuhur2.history) return;
  if (!t.done) {
    // Uncheck Jumat → hapus hari ini dari history Dzuhur
    var rmIdx = dzuhur2.history.indexOf(todayStr);
    if (rmIdx >= 0) {
      dzuhur2.history.splice(rmIdx, 1);
      if (typeof saveData === 'function') saveData(true);
    }
    return;
  }
  // Tambahkan hari ini ke history Sholat Dzuhur agar streaknya jalan
  var dzuhurName = ''; 
  // Cari nama dzuhur dari SHOLAT_NAMES
  if (typeof SHOLAT_NAMES !== 'undefined' && typeof SHOLAT_ICONS !== 'undefined') {
    var idx = SHOLAT_NAMES.indexOf('Dzuhur');
    if (idx >= 0) dzuhurName = SHOLAT_ICONS[idx] + ' Sholat Dzuhur';
  }
  if (!dzuhurName) return;
  var dzuhur = tasks.filter(function(x){ return x.name === dzuhurName; })[0];
  if (!dzuhur) return;
  if (!dzuhur.history) dzuhur.history = [];
  if (dzuhur.history.indexOf(todayStr) < 0) {
    dzuhur.history.push(todayStr);
    if (typeof saveData === 'function') saveData(true);
  }
};

// ── Akumulator damage per langkah (kunci: task id) ──
var _bossStepAccum = {};

// ── Hook toggleStep — damage dikumpulkan, animasi slash hanya saat task selesai ──
var _origToggleStep = toggleStep;
toggleStep = function(id, idx){
  var tBefore = tasks.filter(function(x){ return x.id===id; })[0];
  var stepsBefore = tBefore ? (tBefore.stepsDone||0) : 0;
  var wasDone = tBefore ? tBefore.done : false;
  // Task due masa depan tidak boleh memberikan damage boss
  if(tBefore && tBefore.due && tBefore.due > todayStr) return _origToggleStep(id, idx);
  _origToggleStep(id, idx);
  var tAfter = tasks.filter(function(x){ return x.id===id; })[0];
  if(!tAfter || bossState.defeated) return;
  // Lucky Amstow punya mekanisme sendiri (makan), skip slash
  if(bossCur().id === 'lucky') return;

  var stepsAfter  = tAfter.stepsDone||0;
  var totalSteps  = tAfter.steps||1;
  var newlyChecked = stepsAfter > stepsBefore && !wasDone;
  if(!newlyChecked) return;

  var newCount = (idx==='all') ? (stepsAfter - stepsBefore) : 1;

  if(!_bossStepAccum[id]) _bossStepAccum[id] = {dmgs:[], total:0};
  for(var si=0; si<newCount; si++){
    var d = 20 + Math.floor(Math.random()*21); // 20-40 per langkah
    _bossStepAccum[id].dmgs.push(d);
    _bossStepAccum[id].total += d;
  }

  // Hanya apply + animasi saat semua langkah selesai
  if(tAfter.done || stepsAfter >= totalSteps){
    var acc = _bossStepAccum[id];
    delete _bossStepAccum[id];
    bossMultiSlash(acc.dmgs, acc.total);
  }
};

// Multi-slash: animasi slash berkali-kali melepaskan damage akumulasi
function bossMultiSlash(dmgList, totalDmg){
  if(bossState.defeated) return;

  // If boss is minimized, do a single flash-damage sequence then re-minimize
  if(_bossMinimized){
    bossState.hp = Math.max(0, bossState.hp - totalDmg);
    var defeated = bossState.hp === 0 && !bossState.defeated;
    if(defeated) bossState.defeated = true;
    bossSave(); bossRefresh();
    _bossFlashDamageIfMinimized(totalDmg, defeated ? function(){ bossVictory(); } : null);
    return;
  }

  var pct = bossState.hp/bossState.maxHp;
  var slashCount = Math.min(dmgList.length, 6);
  var dmgPerSlash = Math.floor(totalDmg / slashCount);

  for(var s=0; s<slashCount; s++){
    (function(si){
      var slashDmg = (si===slashCount-1) ? (totalDmg - dmgPerSlash*(slashCount-1)) : dmgPerSlash;
      setTimeout(function(){
        if(bossState.defeated) return;
        bossState.hp = Math.max(0, bossState.hp - slashDmg);
        if(bossState.hp === 0 && !bossState.defeated){
          bossState.defeated = true;
          bossSave(); bossRefresh(); bossAttackAnim(slashDmg);
          setTimeout(function(){ bossVictory(); }, 600);
          return;
        }
        bossSave(); bossRefresh(); bossAttackAnim(slashDmg);
        if(pct > 0.3 && bossState.hp/bossState.maxHp <= 0.3 && si===0){
          setTimeout(function(){
            var el = document.getElementById('bossPhraseEl');
            var b2 = bossCur();
            var rageTaunts = {
              sloth:'"...Ugh... kamu beneran maksa aku serius?! FINE—"',
              procras:'"BAIK BAIK!! Aku gak akan tunda perlawananku!!"',
              distract:'"HEH FOKUS KE AKU SEKARANG — BUKAN KE TUGASMU!!"',
              doubt:'"K-kamu... serius mau lanjut?! KAMU YANG AKAN MENYESAL!!"',
              chaos:'"SEKARANG KAMU AKAN MERASAKAN KEKACAUAN SEJATI!!"'
            };
            var taunt = rageTaunts[b2.id] || '"SEKARANG KAMU AKAN MERASAKAN KEKUATANKU!!"';
            if(el){
              el.textContent = taunt;
              el.style.color = '#ff6b6b';
              el.style.textShadow = '-1px -1px 0 #000,1px -1px 0 #000,-1px 1px 0 #000,1px 1px 0 #000,0 0 16px #ef4444,0 0 32px #ef444488';
              el.style.opacity='1'; el.style.transform='translateY(0) scale(1)';
              setTimeout(function(){ el.style.opacity='0'; el.style.transform='translateY(-6px) scale(0.95)'; el.style.color=''; el.style.textShadow=''; },4000);
            }
          },400);
        }
      }, si * 380);
    })(s);
  }
}

// ── Helper: hide / restore boss behind any overlay ──
function _bossPushBehind(){
  var panel = document.getElementById('bossBattlePanel');
  var tab   = document.getElementById('bossTab');
  if(panel) panel.style.zIndex = '50';
  if(tab)   tab.style.zIndex   = '50';
}
function _bossRestoreFront(){
  var panel = document.getElementById('bossBattlePanel');
  var tab   = document.getElementById('bossTab');
  if(panel) panel.style.zIndex = '201';
  if(tab)   tab.style.zIndex   = '202';
}

// ── Hook openDetail / closeDetail — boss goes behind drawer ──
var _origOpenDetail = openDetail;
openDetail = function(id){
  _origOpenDetail(id);
  _bossPushBehind();
};
var _origCloseDetail = closeDetail;
closeDetail = function(){
  _origCloseDetail();
  // Only restore if no sub-drawer is open
  if(!activeSubDrawer) _bossRestoreFront();
};

// ── Hook toggleSubDrawer / closeSubDrawer ──
var _origToggleSubDrawer = toggleSubDrawer;
toggleSubDrawer = function(name){
  _origToggleSubDrawer(name);
  // After toggle: if a drawer is now open, push boss behind
  if(activeSubDrawer) _bossPushBehind();
  else _bossRestoreFront();
};
var _origCloseSubDrawer = closeSubDrawer;
closeSubDrawer = function(silent){
  _origCloseSubDrawer(silent);
  _bossRestoreFront();
};

// ── Hook mobile add bars ──
var _origOpenMobileAddBar = (typeof openMobileAddBar === 'function') ? openMobileAddBar : null;
if(_origOpenMobileAddBar){
  openMobileAddBar = function(){
    _origOpenMobileAddBar();
    _bossPushBehind();
  };
}
var _origCloseMobileAddBar = (typeof closeMobileAddBar === 'function') ? closeMobileAddBar : null;
if(_origCloseMobileAddBar){
  closeMobileAddBar = function(){
    _origCloseMobileAddBar();
    if(!activeSubDrawer) _bossRestoreFront();
  };
}
var _origOpenMobileFinAddBar = (typeof openMobileFinAddBar === 'function') ? openMobileFinAddBar : null;
if(_origOpenMobileFinAddBar){
  openMobileFinAddBar = function(){
    _origOpenMobileFinAddBar();
    _bossPushBehind();
  };
}
var _origCloseMobileFinAddBar = (typeof closeMobileFinAddBar === 'function') ? closeMobileFinAddBar : null;
if(_origCloseMobileFinAddBar){
  closeMobileFinAddBar = function(){
    _origCloseMobileFinAddBar();
    if(!activeSubDrawer) _bossRestoreFront();
  };
}

// ── Hook mobile sidebar toggle — boss hides behind sidebar drawer ──
var _origToggleSidebar = (typeof toggleSidebar === 'function') ? toggleSidebar : null;
if(_origToggleSidebar){
  toggleSidebar = function(){
    _origToggleSidebar();
    // On mobile, check if sidebar is now open
    if(window.innerWidth <= 700){
      var sb = document.getElementById('sidebar');
      if(sb && sb.classList.contains('mobile-open')) _bossPushBehind();
      else if(!activeSubDrawer) _bossRestoreFront();
    }
  };
}
// ── Apply boss color theme to the panel ──
function bossApplyTheme(){
  var b    = bossCur(); /* nav-mode-anchor */
  var pct  = bossState.hp / bossState.maxHp;

  // Boss identity colors — rage override at <30% HP
  // Lucky exception: saat hampir kenyang (hp rendah = mau kalah = hampir full) tetap emas happy
  var isLucky = b.id === 'lucky';
  var bossCol  = (pct<0.3 && !isLucky) ? '#ef4444' : b.col;
  var bossGlow = (pct<0.3 && !isLucky) ? 'rgba(239,68,68,0.5)' : b.aura;

  // Read active app theme accent from CSS vars
  var root = document.documentElement;
  var themeAccent  = getComputedStyle(root).getPropertyValue('--accent').trim()  || '#d97706';
  var themeBg      = getComputedStyle(root).getPropertyValue('--bg').trim()      || '#f0ede8';
  var themeCard    = getComputedStyle(root).getPropertyValue('--card').trim()     || '#ffffff';
  var themeSidebar = getComputedStyle(root).getPropertyValue('--sidebar').trim()  || '#1c1917';

  // Detect dark app themes — darkMode var is now always up to date
  var isDark = document.body.classList.contains('sololeveling-theme') ||
               document.body.classList.contains('slytherin-theme') ||
               (typeof darkMode !== 'undefined' && darkMode);

  var panel = document.getElementById('bossBattlePanel');
  var tab   = document.getElementById('bossTab');

  // ── PANEL BACKGROUND ──────────────────────────────────────────────────────
  // Dark themes: use sidebar/dark tone blended with boss color
  // Light themes: panel is ALWAYS dark (deep charcoal) — boss arena feels dungeon-like
  //   but tinted with the app's accent so it "belongs" to the theme
  var panelDark1, panelDark2;
  if(isDark){
    // Pull from theme's own sidebar dark tone
    panelDark1 = themeSidebar;
    panelDark2 = themeSidebar;
  } else {
    // For light themes: derive a dark version of the accent color as the panel base
    // Use fixed near-black with accent tint so it's always readable
    panelDark1 = '#0e0e18';
    panelDark2 = '#14101e';
  }
  var panelBg = 'linear-gradient(170deg,'+panelDark1+'f5 0%,'+panelDark2+'ee 60%,'+panelDark1+'f5 100%)';

  if(panel){
    panel.style.background  = panelBg;
    panel.style.borderColor = bossCol;
    panel.style.boxShadow   = '0 0 22px '+bossGlow+', 0 8px 40px rgba(0,0,0,0.9)';
  }

  // ── HEADER BAR ────────────────────────────────────────────────────────────
  var hdr = document.getElementById('bossHeaderBar');
  if(hdr){
    // Always dark header, tinted with boss color
    hdr.style.background       = 'linear-gradient(90deg,'+bossCol+'28,'+bossCol+'10,'+bossCol+'28)';
    hdr.style.borderBottomColor = bossCol+'55';
  }

  // Header title — always use boss glow color (readable on dark)
  var htitle = document.getElementById('bossHeaderTitle');
  if(htitle) htitle.style.color = b.glow;

  // Minimize button — always styled for dark panel
  var minBtn = document.getElementById('bossMinBtn');
  if(minBtn){
    minBtn.style.background  = 'rgba(255,255,255,0.07)';
    minBtn.style.borderColor = 'rgba(255,255,255,0.2)';
    minBtn.style.color       = '#9ca3af';
  }

  // ── SPRITE AREA — ALWAYS DARK (arena/dungeon feel) ────────────────────────
  var sa = document.getElementById('bossSpriteArea');
  if(sa) sa.style.background =
    'radial-gradient(ellipse at 50% 85%,'+bossCol+'55 0%,#060010 70%)';

  // Aura always dark
  var aura = document.getElementById('bossAuraEl');
  if(aura) aura.style.background =
    'radial-gradient(ellipse at 50% 100%,'+bossGlow+' 0%,transparent 70%)';

  // ── BOSS NAME + TEXT — always white/bright on dark panel ──────────────────
  var nameEl = document.getElementById('bossNameEl');
  if(nameEl){
    nameEl.style.color      = '#ffffff';
    nameEl.style.textShadow = '0 0 14px '+bossCol+', 0 0 6px '+bossCol+'aa';
  }
  var subEl = document.getElementById('bossSubEl');
  if(subEl) subEl.style.color = '#9ca3af';

  // HP labels — always readable on dark
  var hpLbls = document.querySelectorAll('.boss-hp-lbl');
  hpLbls.forEach(function(el){ el.style.color = '#9ca3af'; });
  var hpNums = document.getElementById('bossHpNums');
  if(hpNums) hpNums.style.color = '#d1d5db';

  // ── HP TRACK ──────────────────────────────────────────────────────────────
  var track = document.querySelector('.boss-hp-track');
  if(track){
    track.style.background  = '#0a0a1a';
    track.style.borderColor = bossCol+'55';
  }

  // ── BOSS PHRASE ───────────────────────────────────────────────────────────
  var phrase = document.getElementById('bossPhraseEl');
  if(phrase){
    phrase.style.color      = '#ffffff';
    phrase.style.textShadow =
      '-1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000,' +
      '0 0 12px '+bossCol+', 0 0 24px '+bossCol+'88';
  }

  // ── TAB (minimized pill) ──────────────────────────────────────────────────
  // Light themes: dark pill that matches boss + a hint of accent
  // Dark themes: same but slightly lighter
  if(tab){
    var tabBg = isDark
      ? 'linear-gradient(135deg,'+themeSidebar+'f0,'+themeSidebar+'cc)'
      : 'linear-gradient(135deg,#14101e,#0e0e18)';
    tab.style.background  = tabBg;
    tab.style.borderColor = bossCol;
    tab.style.color       = b.glow;
    tab.style.boxShadow   = '0 0 14px '+bossGlow+', 0 2px 8px rgba(0,0,0,0.6)';
  }

  // ── PANEL PULSE ANIMATION ─────────────────────────────────────────────────
  var ps = document.getElementById('bossPanelPulseStyle');
  if(!ps){ ps = document.createElement('style'); ps.id = 'bossPanelPulseStyle'; document.head.appendChild(ps); }
  ps.textContent =
    '#bossBattlePanel{animation:bossDynPulse 3.5s ease infinite!important;}' +
    '@keyframes bossDynPulse{' +
      '0%,100%{box-shadow:0 0 18px '+bossGlow+',0 8px 40px rgba(0,0,0,0.9)}' +
      '50%{box-shadow:0 0 40px '+bossCol+'cc,0 8px 40px rgba(0,0,0,0.9)}' +
    '}';

  // ── LIGHT THEME: add accent stripe on panel border for visual tie-in ──────
  // Inject a subtle accent-colored top bar on the panel when in light mode
  var accentBar = document.getElementById('bossAccentStripe');
  if(!isDark){
    if(!accentBar){
      accentBar = document.createElement('div');
      accentBar.id = 'bossAccentStripe';
      accentBar.style.cssText =
        'position:absolute;top:0;left:0;right:0;height:3px;z-index:10;pointer-events:none;border-radius:12px 12px 0 0;transition:background 0.4s;';
      if(panel) panel.insertBefore(accentBar, panel.firstChild);
    }
    accentBar.style.background =
      'linear-gradient(90deg,transparent,'+themeAccent+','+bossCol+','+themeAccent+',transparent)';
    accentBar.style.opacity = '0.9';
  } else {
    if(accentBar) accentBar.style.opacity = '0';
  }
}

// Tunggu sampai app benar-benar ready (sudah login & gami dipilih)
// sebelum menjalankan bossInit, agar welcome overlay Lucky Amstow
// tidak muncul di halaman login.
(function _waitAppReady(){
  if (window._appReady) {
    bossInit();
  } else {
    setTimeout(_waitAppReady, 300);
  }
})();

